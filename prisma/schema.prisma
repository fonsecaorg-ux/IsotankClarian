generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  INSPETOR
}

enum LaudoStatus {
  EM_INSPECAO
  AGUARDANDO_APROVACAO
  CONCLUIDO
}

model User {
  id           String     @id @default(cuid())
  nome         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(INSPETOR)
  ativo        Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  laudos       Laudo[]    @relation("LaudoCreatedBy")
  auditLogs    AuditLog[]
  documentos   Documento[] @relation("DocumentoUploadedBy")
}

model Laudo {
  id                String      @id @default(cuid())
  status            LaudoStatus @default(EM_INSPECAO)
  numeroIdentificacao String?
  cliente           String?
  endereco          String?
  dataInspecao      DateTime?
  formData          Json
  generatedFileName String?
  generatedAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  createdById       String
  createdBy         User        @relation("LaudoCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  equipamentoId     String?
  equipamento       Equipamento? @relation(fields: [equipamentoId], references: [id])

  auditLogs         AuditLog[]
  fotos             FotoLaudo[]

  @@index([createdById])
  @@index([status])
  @@index([numeroIdentificacao])
  @@index([dataInspecao])
  @@index([equipamentoId])
}

model FotoLaudo {
  id        String   @id @default(uuid())
  laudoId   String
  laudo     Laudo    @relation(fields: [laudoId], references: [id], onDelete: Cascade)
  campo     String
  label     String
  dados     Bytes?
  caminhoArquivo String?
  mimeType  String   @default("image/jpeg")
  tamanho   Int
  createdAt DateTime @default(now())

  @@index([laudoId])
  @@index([campo])
}

model Cliente {
  id           String       @id @default(uuid())
  nome         String       @unique
  endereco     String?
  ativo        Boolean      @default(true)
  equipamentos Equipamento[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Equipamento {
  id                  String    @id @default(uuid())
  numeroIdentificacao String    @unique
  fabricante          String
  numeroSerie         String?
  paisFabricacao      String?
  tamanho             String?
  capacidadeLiquida   String?
  anoFabricacao       String?
  normaFabricacao     String?
  materialCalota      String?
  materialCostado     String?
  espessura           String?
  totalInspecoes      Int       @default(0)
  ultimaInspecao      DateTime?
  proximoVencimento   DateTime?
  ativo               Boolean   @default(true)
  clienteId           String?
  cliente             Cliente?  @relation(fields: [clienteId], references: [id])
  laudos              Laudo[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([clienteId])
  @@index([ativo])
}

model Configuracao {
  id        String   @id @default(uuid())
  chave     String   @unique
  valor     String
  descricao String?
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id          String       @id @default(cuid())
  action      String
  fromStatus  LaudoStatus?
  toStatus    LaudoStatus?
  metadata    Json?
  createdAt   DateTime     @default(now())

  laudoId     String?
  laudo       Laudo?       @relation(fields: [laudoId], references: [id], onDelete: Cascade)

  userId      String?
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([laudoId])
  @@index([userId])
  @@index([createdAt])
}

model Documento {
  id             String   @id @default(uuid())
  nome           String
  descricao      String?
  categoria      String
  nomeArquivo    String
  mimeType       String
  tamanho        Int
  caminhoArquivo String?
  dados          Bytes?
  ativo          Boolean  @default(true)
  uploadedById   String
  uploadedBy     User     @relation("DocumentoUploadedBy", fields: [uploadedById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([categoria])
  @@index([ativo])
  @@index([uploadedById])
}
