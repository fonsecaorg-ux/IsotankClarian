# Copie para ".env" na raiz do projeto (não commite o .env).
#
# --- Opção A: Postgres local com Docker ---
#   docker compose up -d
#   npx prisma migrate deploy
#   npm run dev
#
DATABASE_URL="postgresql://isotank:isotank_local@localhost:5432/isotank?schema=public"

JWT_SECRET=ceinspec_isotank_dev_local
NODE_ENV=development
STORAGE_MODE=database

